# Build-context filters for the website Docker image.
# Context is the REPO ROOT (set by web/docker-compose.yml).
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.idea/
.vscode/
.git/
.github/
node_modules/
*.log

# Streamlit local state — irrelevant to the website image.
.streamlit/
rsconnect-python/

# Stale snapshot — the Dockerfile regenerates it inside the builder stage.
web/site/data/

# Streamlit-only entry point + docs (the website image doesn't need them).
app.py
streamlit_app/
README.md
ONBOARDING.md

# Tests don't need to ship in the image.
tests/
